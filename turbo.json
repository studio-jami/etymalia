{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "ETYMALIA_STUDIO_USER_IDS",
        "GEMINI_API_KEY",
        "POSTGRES_URL",
        "POSTGRES_PRISMA_URL",
        "POSTGRES_URL_NON_POOLING",
        "POSTGRES_USER",
        "POSTGRES_HOST",
        "POSTGRES_PASSWORD",
        "POSTGRES_DATABASE",
        "SUPABASE_ANON_KEY",
        "SUPABASE_URL",
        "SUPABASE_SERVICE_ROLE_KEY",
        "SUPABASE_JWT_SECRET",
        "SUPABASE_PUBLISHABLE_KEY",
        "SUPABASE_SECRET_KEY",
        "CLOUDFLARE_GENERATION_ENDPOINT",
        "CLOUDFLARE_GENERATION_ENQUEUE_SECRET",
        "TRIGGER_SECRET_KEY",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "NEXT_PUBLIC_APP_URL",
        "STRIPE_PRICE_ID_PERSONAL_MONTHLY",
        "ETYMALIA_CREDITS_PERSONAL_MONTHLY",
        "STRIPE_PRICE_ID_PERSONAL_YEARLY",
        "ETYMALIA_CREDITS_PERSONAL_YEARLY",
        "STRIPE_PRICE_ID_ENTREPRENEUR_MONTHLY",
        "ETYMALIA_CREDITS_ENTREPRENEUR_MONTHLY",
        "STRIPE_PRICE_ID_ENTREPRENEUR_YEARLY",
        "ETYMALIA_CREDITS_ENTREPRENEUR_YEARLY",
        "STRIPE_PRICE_ID_BUSINESS_MONTHLY",
        "ETYMALIA_CREDITS_BUSINESS_MONTHLY",
        "STRIPE_PRICE_ID_BUSINESS_YEARLY",
        "ETYMALIA_CREDITS_BUSINESS_YEARLY"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^test"]
    }
  }
}
